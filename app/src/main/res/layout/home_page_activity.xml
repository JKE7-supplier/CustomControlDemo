<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f2f2f2"
    android:theme="@style/Theme.Design.Light.NoActionBar"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/preview_banner"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="画廊 / 模糊视图 / 轮播"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/dash_board_button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="自定义recycler view 的滑动指示器"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/view_page2_button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="View Page2演示"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/view_page3_button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="钜型 圆形 image view 演示"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_4"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Flexbox 使用"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_5"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Text Flow 文本流式布局"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_6"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="图片缩放"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_7"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="MVVM、MVI架构运用"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_8"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="分享sdk"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_9"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="加载pdf"
            tools:ignore="BottomAppBar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_10"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="worker manager"
            tools:ignore="BottomAppBar" />
    </LinearLayout>
</ScrollView>